+ *                     \/            \/     \/    \/            \/
+ *
+ * Bluetooth menu for HiBy R1 hosted Linux targets.
+ ****************************************************************************/
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdbool.h>
+#include <string.h>
+#include <stdarg.h>
+#include <time.h>
+#include <sys/stat.h>
+#include <fcntl.h>
+
+#include "config.h"
+
+#if defined(HIBY_R1) && !defined(SIMULATOR)
+
+#include "rbpaths.h"
+#include "menu.h"
+#include "gui/list.h"
+#include "action.h"
+#include "splash.h"
+#include "system.h"
+#include "audio.h"
+#include "kernel.h"
+#include "logf.h"
+#include "file.h"
+
+#define BT_LOG_PATH ROCKBOX_DIR "/bt_debug.log"
+#define BT_ALSA_DEVICE_FILE ROCKBOX_DIR "/alsa_device.txt"
+#define BT_SINK_PATH_FILE ROCKBOX_DIR "/bt_sink_path.txt"
+#define BT_SOURCE_PATH_FILE ROCKBOX_DIR "/bt_source_path.txt"
+#define BT_FIXED_MAC "80:99:E7:88:94:BC"
+#define BT_PCM_FMT "bluealsa:DEV=%s,PROFILE=a2dp"
+
+struct bt_device_entry {
+    char mac[18];
+    char name[96];
+    bool paired;
+};
+
+static struct bt_device_entry bt_devices[64];
+static int bt_device_count;
+static int bt_switch_output(const char *dev);
+static int bt_connect_device(const char *mac);
+static char bt_selected_mac[18] = "";
+
+static void bt_log(const char *fmt, ...)
+{
+    mkdir(ROCKBOX_DIR, 0755);
+
+    int fd = open(BT_LOG_PATH, O_WRONLY | O_CREAT | O_APPEND, 0644);
+    if (fd < 0)
+        return;
+
+    char line[512];
+    time_t now = time(NULL);
+    struct tm tmv;
+    localtime_r(&now, &tmv);
+    int len = snprintf(line, sizeof(line), "[%04d-%02d-%02d %02d:%02d:%02d] ",
+                       tmv.tm_year + 1900, tmv.tm_mon + 1, tmv.tm_mday,
+                       tmv.tm_hour, tmv.tm_min, tmv.tm_sec);
+
+    va_list ap;
+    va_start(ap, fmt);
+    len += vsnprintf(line + len, sizeof(line) - len, fmt, ap);
+    va_end(ap);
+    if (len < (int)sizeof(line) - 1)
+        line[len++] = '\n';
+
+    write(fd, line, MIN((size_t)len, sizeof(line)));
+    close(fd);
+}
+
+static int bt_run_cmd(const char *cmd)
+{
+    int rc;
+    bt_log("CMD: %s", cmd);
+    rc = system(cmd);
+    bt_log("CMD rc=%d", rc);
+    return rc;
+}
+
+static bool bt_device_exists(const char *mac)
+{
+    for (int i = 0; i < bt_device_count; i++)
+        if (strcmp(bt_devices[i].mac, mac) == 0)
+            return true;
+    return false;
+}
+
+static void bt_trim(char *s)
+{
+    size_t n = strlen(s);
+    while (n > 0 && (s[n - 1] == '\n' || s[n - 1] == '\r' || s[n - 1] == ' ' || s[n - 1] == '\t'))
+        s[--n] = '\0';
+}
+
+static void bt_collect_from_cmd(const char *cmd, bool mark_paired)
+{
+    FILE *fp = popen(cmd, "r");
+    if (!fp)
+    {
+        bt_log("Failed to run: %s", cmd);
+        return;
+    }
+
+    char line[256];
+    while (fgets(line, sizeof(line), fp))
+    {
+        char mac[18] = {0};
+        char name[96] = {0};
+
+        if (sscanf(line, "Device %17s %95[^\n]", mac, name) < 2)
+            continue;
+
+        bt_trim(name);
+
+        if (bt_device_exists(mac))
+        {
+            if (mark_paired)
+            {
+                for (int i = 0; i < bt_device_count; i++)
+                {
+                    if (strcmp(bt_devices[i].mac, mac) == 0)
+                    {
+                        bt_devices[i].paired = true;
+                        break;
+                    }
+                }
+            }
+            continue;
+        }
+
+        if (bt_device_count >= (int)ARRAYLEN(bt_devices))
+            break;
+
+        snprintf(bt_devices[bt_device_count].mac,
+                 sizeof(bt_devices[bt_device_count].mac), "%s", mac);
+        snprintf(bt_devices[bt_device_count].name,
+                 sizeof(bt_devices[bt_device_count].name), "%s",
+                 name[0] ? name : "(unnamed)");
+        bt_devices[bt_device_count].paired = mark_paired;
+        bt_device_count++;
+    }
+
+    pclose(fp);
+}
+
+static int bt_scan_devices(void)
+{
+    bt_device_count = 0;
+
+    bt_run_cmd("/usr/bin/bt_resume >/dev/null 2>&1");
+    bt_run_cmd("/usr/bin/bluealsa_profile a2dp-source >/dev/null 2>&1");
+    bt_run_cmd("bluetoothctl --timeout 8 scan on >/dev/null 2>&1");
+
+    bt_collect_from_cmd("bluetoothctl devices 2>/dev/null", false);
+    bt_collect_from_cmd("bluetoothctl paired-devices 2>/dev/null", true);
+
+    bt_log("scan complete, found %d devices", bt_device_count);
+    return bt_device_count;
+}
+
+static bool bt_is_connected(const char *mac)
+{
+    char cmd[96];
+    snprintf(cmd, sizeof(cmd), "bluetoothctl info %s 2>/dev/null", mac);
+
+    FILE *fp = popen(cmd, "r");
+    if (!fp)
+        return false;
+
+    char line[256];
+    bool connected = false;
+    while (fgets(line, sizeof(line), fp))
+    {
+        if (strstr(line, "Connected: yes"))
+        {
+            connected = true;
+            break;
+        }
+    }
+
+    pclose(fp);
+    return connected;
+}
+
+static int bt_update_alsa_conf(const char *mac)
+{
+    FILE *in = fopen("/usr/data/alsa.conf", "r");
+    if (!in)
+    {
+        bt_log("/usr/data/alsa.conf not found, skipping update");
+        return 0;
+    }
+
+    FILE *out = fopen("/tmp/rb_alsa.conf.tmp", "w");
+    if (!out)
+    {
+        fclose(in);
+        bt_log("failed to open /tmp/rb_alsa.conf.tmp");
+        return -1;
+    }
+
+    char line[512];
+    bool pcm_updated = false;
+    bool device_updated = false;
+    while (fgets(line, sizeof(line), in))
+    {
+        char *p = line;
+        while (*p == ' ' || *p == '\t')
+            p++;
+
+        if (!pcm_updated && strncmp(p, "pcm.", 4) == 0)
+        {
+            fprintf(out, "pcm.bluealsa:DEV=%s {\n", mac);
+            pcm_updated = true;
+            continue;
+        }
+
+        if (strncmp(p, "device ", 7) == 0)
+        {
+            fprintf(out, "            device %s\n", mac);
+            device_updated = true;
+            continue;
+        }
+
+        fputs(line, out);
+    }
+
+    fclose(in);
+    fclose(out);
+
+    if (rename("/tmp/rb_alsa.conf.tmp", "/usr/data/alsa.conf") != 0)
+    {
+        bt_log("failed to update /usr/data/alsa.conf");
+        return -1;
+    }
+
+    bt_log("updated /usr/data/alsa.conf with MAC %s (pcm=%d device=%d)",
+           mac, pcm_updated ? 1 : 0, device_updated ? 1 : 0);
+    return 0;
+}
+
+static int bt_write_text_file(const char *path, const char *value)
+{
+    mkdir(ROCKBOX_DIR, 0755);
+
+    int fd = open(path, O_WRONLY | O_CREAT | O_TRUNC, 0644);
+    if (fd < 0)
+        return -1;
+
+    write(fd, value, strlen(value));
+    write(fd, "\n", 1);
+    close(fd);
+    bt_log("wrote %s = %s", path, value);
+    return 0;
+}
+
+static int bt_write_rb_alsa_device(const char *dev)
+{
+    return bt_write_text_file(BT_ALSA_DEVICE_FILE, dev);
+}
+
+static bool bt_is_connected_bt_device(const char *mac)
+{
+    FILE *fp = popen("/usr/bin/bt-device -l 2>/dev/null", "r");
+    if (!fp)
+        return false;
+
+    char line[256];
+    bool found = false;
+    while (fgets(line, sizeof(line), fp))
+    {
+        if (strstr(line, mac))
+        {
+            found = true;
+            break;
+        }
+    }
+
+    pclose(fp);
+    return found;
+}
+
+static bool bt_is_connected_any(const char *mac)
+{
+    if (bt_is_connected(mac))
+        return true;
+    return bt_is_connected_bt_device(mac);
+}
+
+static void bt_mac_to_underscore(const char *mac, char *out, size_t out_sz)
+{
+    size_t j = 0;
+    for (size_t i = 0; mac[i] && j + 1 < out_sz; i++)
+        out[j++] = (mac[i] == ':') ? '_' : mac[i];
+    out[j] = '\0';
+}
+
+static bool bt_wait_for_bluealsa_pcm(const char *mac, int timeout_ticks)
+{
+    char mac_u[18];
+    int ticks = 0;
+
+    bt_mac_to_underscore(mac, mac_u, sizeof(mac_u));
+    while (ticks < timeout_ticks)
+    {
+        FILE *fp = popen("bluealsa-cli list-pcms 2>/dev/null", "r");
+        if (fp)
+        {
+            char line[256];
+            while (fgets(line, sizeof(line), fp))
+            {
+                if (strstr(line, mac_u) && strstr(line, "/a2dpsrc/sink"))
+                {
+                    pclose(fp);
+                    bt_log("BlueALSA PCM ready for %s", mac);
+                    return true;
+                }
+            }
+            pclose(fp);
+        }
+        sleep(HZ / 5);
+        ticks += HZ / 5;
+    }
+
+    bt_log("BlueALSA PCM timeout for %s", mac);
+    return false;
+}
+
+static bool bt_stack_ready(const char *mac)
+{
+    return bt_is_connected_any(mac) && bt_wait_for_bluealsa_pcm(mac, HZ / 2);
+}
+
+static void bt_force_sbc_codec(const char *mac)
+{
+    char mac_u[18];
+    char pcm_path[96];
+    char cmd[256];
+
+    bt_mac_to_underscore(mac, mac_u, sizeof(mac_u));
+    snprintf(pcm_path, sizeof(pcm_path),
+             "/org/bluealsa/hci0/dev_%s/a2dpsrc/sink", mac_u);
+    snprintf(cmd, sizeof(cmd),
+             "bluealsa-cli codec '%s' SBC >/tmp/rb_bt_codec.log 2>&1", pcm_path);
+    bt_run_cmd(cmd);
+}
+
+static void bt_prepare_stack(void)
+{
+    bt_run_cmd("([ -x /tmp/sys_server_cli ] && /tmp/sys_server_cli bt on) >/dev/null 2>&1 || true");
+    bt_run_cmd("([ -x /tmp/sys_server_cli ] && /tmp/sys_server_cli bt a2dp a2dp-source) >/dev/null 2>&1 || true");
+    bt_run_cmd("bluetoothctl power on >/dev/null 2>&1");
+}
+
+static void bt_set_sink_and_source_path(const char *mac)
+{
+    char pcm_name[96];
+    snprintf(pcm_name, sizeof(pcm_name), BT_PCM_FMT, mac);
+
+    bt_write_text_file(BT_SINK_PATH_FILE, pcm_name);
+    bt_write_text_file(BT_SOURCE_PATH_FILE, pcm_name);
+    bt_write_rb_alsa_device(pcm_name);
+
+    /* Try exact device path first; keep generic fallback for compatibility. */
+    if (system_set_audio_output_device(pcm_name) != 0)
+        system_set_audio_output_device("bluealsa");
+
+    bt_log("applied sink/source path: %s", pcm_name);
+}
+
+static int bt_connect_sequence(const char *mac)
+{
+    return bt_connect_device(mac);
+}
+
+static int bt_connect_fixed_mac(void *param)
+{
+    (void)param;
+
+    splash(HZ/2, "BT init/connect...");
+    if (bt_connect_sequence(BT_FIXED_MAC) != 0)
+    {
+        bt_log("connect failed: %s", BT_FIXED_MAC);
+        splash(HZ, "Connect failed");
+        return 0;
+    }
+
+    bt_set_sink_and_source_path(BT_FIXED_MAC);
+    snprintf(bt_selected_mac, sizeof(bt_selected_mac), "%s", BT_FIXED_MAC);
+
+    {
+        char pcm_name[96];
+        snprintf(pcm_name, sizeof(pcm_name), BT_PCM_FMT, BT_FIXED_MAC);
+        if (bt_switch_output(pcm_name) == 0)
+        {
+            splash(HZ, "Bluetooth connected");
+            return 0;
+        }
+    }
+
+    splash(HZ, "Connected; route fail");
+    return 0;
+}
+
+static int bt_switch_output(const char *dev)
+{
+    int status = audio_status();
+    bool was_paused = status & AUDIO_STATUS_PAUSE;
+    bool was_playing = status & AUDIO_STATUS_PLAY;
+
+    if (was_playing && !was_paused)
+    {
+        audio_pause();
+        sleep(HZ/5);
+    }
+
+    if (system_set_audio_output_device(dev) != 0)
+    {
+        bt_log("runtime route switch failed for %s", dev);
+        if (was_playing && !was_paused)
+            audio_resume();
+        return -1;
+    }
+
+    if (was_playing && !was_paused)
+    {
+        sleep(HZ/2);
+        audio_resume();
+    }
+
+    bt_log("runtime route switched to %s", dev);
+    return 0;
+}
+
+static int bt_connect_device(const char *mac)
+{
+    char cmd[192];
+    char mac_u[18];
+    char pcm_name[96];
+
+    bt_prepare_stack();
+
+    snprintf(cmd, sizeof(cmd), "bluetoothctl connect %s >/dev/null 2>&1", mac);
+    bt_run_cmd(cmd);
+    sleep(HZ);
+
+    if (!bt_is_connected_any(mac))
+    {
+        bt_mac_to_underscore(mac, mac_u, sizeof(mac_u));
+        snprintf(cmd, sizeof(cmd),
+                 "([ -x /tmp/sys_server_cli ] && /tmp/sys_server_cli bt connect %s) >/dev/null 2>&1",
+                 mac_u);
+        bt_run_cmd(cmd);
+        sleep(HZ);
+    }
+
+    if (!bt_is_connected_any(mac))
+    {
+        bt_log("device %s did not report connected", mac);
+        return -1;
+    }
+
+    if (!bt_wait_for_bluealsa_pcm(mac, HZ * 8))
+    {
+        return -1;
+    }
+
+    bt_force_sbc_codec(mac);
+    bt_set_sink_and_source_path(mac);
+    snprintf(bt_selected_mac, sizeof(bt_selected_mac), "%s", mac);
+    snprintf(pcm_name, sizeof(pcm_name), BT_PCM_FMT, mac);
+
+    if (bt_switch_output(pcm_name) == 0)
+    {
+        splash(HZ, "Bluetooth connected");
+        return 0;
+    }
+
+    return -1;
+}
+
+static int bt_disconnect_current(void)
+{
+    bt_run_cmd("bluetoothctl disconnect >/dev/null 2>&1");
+    bt_switch_output("plughw:0,0");
+    bt_write_rb_alsa_device("plughw:0,0");
+    bt_selected_mac[0] = '\0';
+    splash(HZ, "Bluetooth disconnected");
+    return 0;
+}
+
+static const char *bt_list_get_name(int item, void *data, char *buffer, size_t buffer_len)
+{
+    (void)data;
+    snprintf(buffer, buffer_len, "%s%s (%s)",
+             bt_devices[item].name,
+             bt_devices[item].paired ? " [paired]" : "",
+             bt_devices[item].mac);
+    return buffer;
+}
+
+static int bt_list_action_cb(int action, struct gui_synclist *lists)
+{
+    (void)lists;
+    if (action == ACTION_STD_OK)
+        return ACTION_STD_CANCEL;
+    return action;
+}
+
+static int bt_scan_and_connect(void *param)
+{
+    (void)param;
+
+    splash(HZ/2, "Bluetooth scan...");
+    int count = bt_scan_devices();
+    if (count <= 0)
+    {
+        splash(HZ, "No devices found");
+        return 0;
+    }
+
+    struct simplelist_info info;
+    simplelist_info_init(&info, "Bluetooth devices", count, NULL);
+    info.get_name = bt_list_get_name;
+    info.action_callback = bt_list_action_cb;
+    info.selection = -1;
+    info.title_icon = Icon_Submenu;
+
+    while (true)
+    {
+        simplelist_show_list(&info);
+        if (info.selection < 0)
+            break;
+
+        int idx = info.selection;
+        bt_log("Selected device: %s (%s)", bt_devices[idx].name, bt_devices[idx].mac);
+        splash(HZ/2, "Bluetooth connect...");
+
+        if (bt_connect_device(bt_devices[idx].mac) == 0)
+            break;
+
+        splash(HZ, "Connect failed");
+    }
+
+    return 0;
+}
+
+static int bt_resume_stack(void *param)
+{
+    (void)param;
+    bt_prepare_stack();
+    splash(HZ/2, "Bluetooth resumed");
+    return 0;
+}
+
+static int bt_suspend_stack(void *param)
+{
+    (void)param;
+    bt_run_cmd("/usr/bin/bt_suspend >/dev/null 2>&1");
+    splash(HZ/2, "Bluetooth suspended");
+    return 0;
+}
+
+static int bt_switch_to_bt(void *param)
+{
+    char pcm_name[96];
+    const char *mac = bt_selected_mac[0] ? bt_selected_mac : BT_FIXED_MAC;
+
+    (void)param;
+    if (!bt_stack_ready(mac))
+        bt_prepare_stack();
+    bt_wait_for_bluealsa_pcm(mac, HZ * 6);
+    bt_force_sbc_codec(mac);
+    snprintf(pcm_name, sizeof(pcm_name), BT_PCM_FMT, mac);
+    bt_write_rb_alsa_device(pcm_name);
+    if (bt_switch_output(pcm_name) == 0)
+        splash(HZ/2, "Output -> Bluetooth");
+    else
+        splash(HZ, "Switch failed");
+    return 0;
+}
+
+static int bt_switch_to_local(void *param)
+{
+    (void)param;
+    bt_write_rb_alsa_device("plughw:0,0");
+    if (bt_switch_output("plughw:0,0") == 0)
+        splash(HZ/2, "Output -> local");
+    else
+        splash(HZ, "Switch failed");
+    return 0;
+}
+
+static int bt_show_route(void *param)
+{
+    (void)param;
+    const char *route = system_get_audio_output_device();
+    if (!route)
+        route = "(unknown)";
+    splashf(HZ, "Route: %s", route);
+    return 0;
+}
+
+MENUITEM_FUNCTION(bt_scan_connect_item, 0, "Scan and Connect",
+                  bt_scan_and_connect, NULL, Icon_Submenu);
+MENUITEM_FUNCTION(bt_connect_fixed_item, 0, "Connect Saved Device",
+                  bt_connect_fixed_mac, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_disconnect_item, 0, "Disconnect",
+                  bt_disconnect_current, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_switch_bt_item, 0, "Switch Output: Bluetooth",
+                  bt_switch_to_bt, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_switch_local_item, 0, "Switch Output: Local",
+                  bt_switch_to_local, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_resume_item, 0, "Bluetooth Resume",
+                  bt_resume_stack, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_suspend_item, 0, "Bluetooth Suspend",
+                  bt_suspend_stack, NULL, Icon_NOICON);
+MENUITEM_FUNCTION(bt_route_item, 0, "Current Output Route",
+                  bt_show_route, NULL, Icon_NOICON);
+
+MAKE_MENU(bluetooth_menu, "Bluetooth", 0, Icon_Submenu,
+          &bt_scan_connect_item,
+          &bt_connect_fixed_item,
+          &bt_disconnect_item,
+          &bt_switch_bt_item,
+          &bt_switch_local_item,
+          &bt_resume_item,
+          &bt_suspend_item,
+          &bt_route_item);
+
+#endif /* HIBY_R1 && !SIMULATOR */
