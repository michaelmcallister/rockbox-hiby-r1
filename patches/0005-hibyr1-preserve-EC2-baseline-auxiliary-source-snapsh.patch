+    playback_dev = device;
+    if (!handle)
+    {
+        pcm_bt_trace("switch_playback_device (no active handle): %s", device);
+        return 0;
+    }
+
+    pthread_mutex_lock(&pcm_mtx);
+    open_hwdev(playback_dev, SND_PCM_STREAM_PLAYBACK);
+    pcm_dma_apply_settings_nolock();
+    pthread_mutex_unlock(&pcm_mtx);
+    pcm_bt_trace("switch_playback_device (active): %s", device);
+    return 0;
+}
