+        }
+    }
+#endif
+
+#ifdef AUTOROCK
+    {
+        const char *file = ""AUTOROCK;
+        file = *file
+                ? file
+                :
+#ifdef APPLICATION
+                                ROCKBOX_DIR
+#else
+                                PLUGIN_APPS_DIR
