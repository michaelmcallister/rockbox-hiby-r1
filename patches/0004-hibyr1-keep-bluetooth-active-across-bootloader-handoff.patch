From 97db03dbfa75d7b8ecc865a2ca127efa0c949c01 Mon Sep 17 00:00:00 2001
From: rockbox-hiby-r1-ci <ci@example.invalid>
Date: Sun, 8 Mar 2026 19:15:00 +0000
Subject: [PATCH 5/5] hibyr1: keep bluetooth active across handoff; enable+fix
 bootloader logging

Bootloader (hibyos_linux.c) changes for the R1:

1. Drop HIBY_R1 from the bt_suspend-on-boot guard so Bluetooth stays
   active across the bootloader -> Rockbox handoff.

2. Enable ENABLE_LOGGING AND move the log-redirect block to after
   mount_storage(true). open_log() writes to the SD card (BASE_DIR);
   running it before the card is mounted failed silently, which is why
   rockbox.log was never created. With it after the mount, the bootloader
   redirects stdout/stderr to /data/mnt/sd_0/rockbox.log and execve()s
   Rockbox with those fds inherited, so Rockbox logf()/crash output is
   captured for post-mortem. Pairs with the shipped unstripped rockbox.elf.

Requires a full r1_rb.upt flash (bootloader is on read-only squashfs).

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 bootloader/hibyos_linux.c | 47 +++++++++++++++++++++++----------------
 1 file changed, 28 insertions(+), 19 deletions(-)

diff --git a/bootloader/hibyos_linux.c b/bootloader/hibyos_linux.c
index edda204796..ce29b3b170 100644
--- a/bootloader/hibyos_linux.c
+++ b/bootloader/hibyos_linux.c
@@ -47,7 +47,11 @@
 #include <stdarg.h>
 #include "version.h"
 
-//#define ENABLE_LOGGING
+/* Enabled on the R1 so the bootloader redirects stdout/stderr to
+ * BASE_DIR/rockbox.log. The Rockbox binary is exec'd with these fds
+ * inherited, so its crash backtrace (rb_backtrace prints to stdout) is
+ * captured to a file for post-mortem instead of only hitting /dev/console. */
+#define ENABLE_LOGGING
 //#define AUTO_ENABLE_ADB
 
 /* Basic configuration */
@@ -634,22 +638,6 @@ int main(int argc, char **argv)
     adb(1);
 #endif
 
-    #ifdef ENABLE_LOGGING
-    /* redirect stdout and stderr to have error messages logged somewhere on the
-     * user partition */
-    int fd = open_log();
-    if(fd >= 0)
-    {
-        dup2(fd, fileno(stdout));
-        dup2(fd, fileno(stderr));
-        close(fd);
-    }
-    /* print version */
-    printf("Rockbox boot loader\n");
-    printf("Version: %s\n", rbversion);
-    printf("%s\n", MODEL_NAME);
-    #endif
-
     system_init();
     core_allocator_init();
     kernel_init();
@@ -666,6 +654,27 @@ int main(int argc, char **argv)
 
     mount_storage(true);
 
+    #ifdef ENABLE_LOGGING
+    /* redirect stdout and stderr to have error messages logged somewhere on
+     * the user partition. Must come AFTER mount_storage(): open_log() writes
+     * to the SD card (BASE_DIR), so the open fails silently if the card is
+     * not mounted yet (this is why rockbox.log was never created). The
+     * Rockbox binary is exec'd later with these fds still open, so it
+     * inherits the redirect and its logf()/crash output lands in
+     * rockbox.log. */
+    int fd = open_log();
+    if(fd >= 0)
+    {
+        dup2(fd, fileno(stdout));
+        dup2(fd, fileno(stderr));
+        close(fd);
+    }
+    /* print version */
+    printf("Rockbox boot loader\n");
+    printf("Version: %s\n", rbversion);
+    printf("%s\n", MODEL_NAME);
+    #endif
+
     /* run all tools menu */
     while(true)
     {
@@ -694,8 +703,8 @@ int main(int argc, char **argv)
         }
         else if(mode == BOOT_ROCKBOX)
         {
-#if defined(HIBY_R3PROII) || defined(HIBY_R1)
-            /* Suspend bluetooth as it's not currently supported */
+#if defined(HIBY_R3PROII)
+            /* Suspend bluetooth before booting Rockbox. */
             system("/usr/bin/bt_suspend");
 #endif
             fflush(stdout);
