From 0eb174ab084ae4b07b178ceece66f3415bfd1f5b Mon Sep 17 00:00:00 2001
From: Codex <codex@example.invalid>
Date: Sun, 8 Mar 2026 17:58:42 +0000
Subject: [PATCH] hibyr1: fix start directory and usb attach handling

---
 apps/main.c |  1 +
 apps/misc.c | 28 ++++++++++++++++++++++++++++
 apps/misc.h |  1 +
 3 files changed, 30 insertions(+)

diff --git a/apps/main.c b/apps/main.c
index c25847430f..2dae97544b 100644
--- a/apps/main.c
+++ b/apps/main.c
@@ -230,6 +230,7 @@ int main(void)
 #endif /* #ifdef AUTOROCK */
 
     global_status.last_volume_change = 0;
+    validate_start_directory_init();
     /* no calls INIT_ATTR functions after this point anymore!
      * see definition of INIT_ATTR in config.h */
     CHART(">root_menu");
diff --git a/apps/misc.c b/apps/misc.c
index 05f1fa6a93..d0d4a7e740 100644
--- a/apps/misc.c
+++ b/apps/misc.c
@@ -660,6 +660,11 @@ long default_event_handler_ex(long event, void (*callback)(void *), void *parame
             intptr_t seqnum = button_get_data();
             if (callback != NULL)
                 callback(parameter);
+#if defined(HIBY_R1)
+            /* Keep Rockbox active with USB attached on HiBy R1. */
+            usb_acknowledge(SYS_USB_CONNECTED_ACK, seqnum);
+            return 0;
+#endif
             system_flush();
 #ifdef BOOTFILE
 #if !defined(USB_NONE) && !defined(USB_HANDLED_BY_OF)
@@ -2018,4 +2023,27 @@ void clear_screen_buffer(bool update)
     }
 }
 
+void validate_start_directory_init(void) /* INIT_ATTR */
+{
+    char * const dirpath = global_settings.start_directory;
+    char *slash = strrchr(dirpath, PATH_SEPCH);
+
+    if (!slash)
+    {
+        path_append(dirpath, PATH_ROOTSTR, PA_SEP_HARD,
+                    sizeof(global_settings.start_directory));
+        return; /* if this doesn't exist we have bigger issues */
+    }
+    else if(slash[1] != '\0') /* ending slash required */
+    {
+        path_append(dirpath, dirpath, PA_SEP_HARD,
+                    sizeof(global_settings.start_directory));
+    }
+    if (slash != dirpath && !dir_exists(dirpath))
+    {
+        path_append(dirpath, PATH_ROOTSTR,
+            PA_SEP_HARD, sizeof(global_settings.start_directory));
+    }
+}
+
 #endif /* ndef __PCTOOL__ */
diff --git a/apps/misc.h b/apps/misc.h
index fd326c5a7d..b513e94675 100644
--- a/apps/misc.h
+++ b/apps/misc.h
@@ -128,6 +128,7 @@ long default_event_handler_ex(long event, void (*callback)(void *), void *parame
 long default_event_handler(long event);
 bool list_stop_handler(void);
 void car_adapter_mode_init(void) INIT_ATTR;
+void validate_start_directory_init(void) INIT_ATTR;
 
 /* Unicode byte order mark sequences and lengths */
 #define BOM_UTF_8 "\xef\xbb\xbf"
