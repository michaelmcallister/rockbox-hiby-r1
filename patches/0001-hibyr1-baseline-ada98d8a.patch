+void disable_adb(void) {
+    // Remove any lingering adb daemon
+    system("killall -9 adbd");
+
+    // Remove the adb link to config
+    if (access("/sys/kernel/config/usb_gadget/adb_demo/configs/c.1/ffs.adb", F_OK) == 0) {
