+static bool hiby_parse_bluealsa_mac_underscore(const char *device, char *mac, size_t mac_size)
+{
+    const char *dev_key = "DEV=";
+    const char *start;
+    size_t i = 0;
+
+    if (!device || !mac || mac_size < 18)
+        return false;
+
+    start = strstr(device, dev_key);
+    if (!start)
+        return false;
+    start += strlen(dev_key);
+
+    while (start[i] && start[i] != ',' && i + 1 < mac_size)
+    {
