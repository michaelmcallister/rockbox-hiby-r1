+static int refresh_data(struct info_data *info)
+{
+    int i = 0;
+#ifdef HAVE_MULTIVOLUME
+#ifdef HAVE_MULTIDRIVE
+    int max = -1;
+    int special = 0;
+#endif
+    int drive = 0;
+    for (i = 0 ; i < NUM_VOLUMES ; i++)
