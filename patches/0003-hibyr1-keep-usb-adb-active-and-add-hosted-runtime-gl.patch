+static void panic_log_to_file(const char *msg)
+{
+    int fd = open(ROCKBOX_DIR "/crash.log", O_WRONLY | O_CREAT | O_APPEND, 0644);
+    if (fd < 0)
+        return;
+
+    char line[256];
+    time_t now = time(NULL);
+    struct tm tmv;
+    localtime_r(&now, &tmv);
+    int len = snprintf(line, sizeof(line), "[%04d-%02d-%02d %02d:%02d:%02d] panic: %s\n",
+                       tmv.tm_year + 1900, tmv.tm_mon + 1, tmv.tm_mday,
+                       tmv.tm_hour, tmv.tm_min, tmv.tm_sec, msg ? msg : "(null)");
+    write(fd, line, MIN((size_t)len, sizeof(line)));
+    close(fd);
+}
+#endif
