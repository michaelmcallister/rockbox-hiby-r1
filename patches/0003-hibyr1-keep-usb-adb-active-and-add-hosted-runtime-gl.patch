+#ifdef HIBY_R1
+/* Persist simple bootloader settings on the SD card so they survive reboot. */
+#define BT_MODE_FILE   BASE_DIR "/.rockbox/bt_mode.txt"
+#define ALSA_DEV_FILE  BASE_DIR "/.rockbox/alsa_device.txt"
+
+/* We only need a 2-state toggle for launch behavior:
+ * - suspend: call /usr/bin/bt_suspend before launching Rockbox
+ * - keep: do not touch bluetooth state
+ *
+ * If the user needs to bring BT up from a cold start, that should be done
+ * explicitly (e.g. via the OF or a separate action), not implicitly here. */
+static bool get_bt_suspend_on_boot(void)
+{
+    mount_storage(true);
+    int fd = open(BT_MODE_FILE, O_RDONLY);
+    if (fd < 0)
+        return true; /* Preserve existing behavior by default */
+
+    char ch = 0;
+    int n = read(fd, &ch, 1);
+    close(fd);
+
+    if (n != 1)
+        return true;
+
+    /* Legacy: '2' used to mean "resume" - treat that as KEEP. */
+    if (ch == '1' || ch == '2')
+        return false;
+    return true;
+}
+
+static void set_bt_suspend_on_boot(bool suspend)
+{
+    mount_storage(true);
+    int fd = open(BT_MODE_FILE, O_WRONLY | O_CREAT | O_TRUNC, 0644);
+    if (fd < 0)
+        return;
+    char ch = suspend ? '0' : '1';
+    write(fd, &ch, 1);
+    close(fd);
+}
+
+static void toggle_bt_suspend_on_boot(void)
+{
+    bool suspend = get_bt_suspend_on_boot();
+    set_bt_suspend_on_boot(!suspend);
+}
+
+static void bt_mode_to_string(bool suspend, char *buf, size_t bufsz)
+{
+    const char *s = suspend ? "BT: off" : "BT: on";
+    snprintf(buf, bufsz, "%s", s);
+}
+
+static void read_alsa_dev(char *buf, size_t bufsz)
+{
+    /* Default matches Rockbox's current compiled-in DEFAULT_PLAYBACK_DEVICE. */
+    snprintf(buf, bufsz, "plughw:0,0");
+
+    mount_storage(true);
+    int fd = open(ALSA_DEV_FILE, O_RDONLY);
+    if (fd < 0)
+        return;
+
+    ssize_t n = read(fd, buf, bufsz - 1);
+    close(fd);
+    if (n <= 0)
+        return;
+
+    buf[n] = '\0';
+    /* Trim newline(s). */
+    for (ssize_t i = n - 1; i >= 0; i--)
+    {
+        if (buf[i] == '\n' || buf[i] == '\r')
+            buf[i] = '\0';
+        else
+            break;
+    }
+    if (buf[0] == '\0')
+        snprintf(buf, bufsz, "plughw:0,0");
+}
+
+static void write_alsa_dev(const char *dev)
+{
+    mount_storage(true);
+    int fd = open(ALSA_DEV_FILE, O_WRONLY | O_CREAT | O_TRUNC, 0644);
+    if (fd < 0)
+        return;
+    write(fd, dev, strlen(dev));
+    write(fd, "\n", 1);
+    close(fd);
+}
+
+static void cycle_alsa_dev(void)
+{
+    char cur[64];
+    read_alsa_dev(cur, sizeof(cur));
+
+    if (strcmp(cur, "plughw:0,0") == 0)
+        write_alsa_dev("default");
+    else if (strcmp(cur, "default") == 0)
+        write_alsa_dev("bluealsa");
+    else
+        write_alsa_dev("plughw:0,0");
+}
+#endif /* HIBY_R1 */
