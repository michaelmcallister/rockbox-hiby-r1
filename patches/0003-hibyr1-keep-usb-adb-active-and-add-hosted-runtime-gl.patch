+static void append_hosted_log(const char *path, const char *fmt, ...)
+{
+    int fd = open(path, O_WRONLY | O_CREAT | O_APPEND, 0644);
+    if (fd < 0)
+        return;
+
+    char line[384];
+    time_t now = time(NULL);
+    struct tm tmv;
+    localtime_r(&now, &tmv);
+    int len = snprintf(line, sizeof(line), "[%04d-%02d-%02d %02d:%02d:%02d] ",
+                       tmv.tm_year + 1900, tmv.tm_mon + 1, tmv.tm_mday,
+                       tmv.tm_hour, tmv.tm_min, tmv.tm_sec);
+
+    va_list ap;
+    va_start(ap, fmt);
+    len += vsnprintf(line + len, sizeof(line) - len, fmt, ap);
+    va_end(ap);
+    if (len < (int)sizeof(line) - 1)
+        line[len++] = '\n';
+
+    write(fd, line, MIN((size_t)len, sizeof(line)));
+    close(fd);
+}
+
 static void sig_handler(int sig, siginfo_t *siginfo, void *context)
 {
     /* safe guard variable - we call backtrace() only on first
@@ -61,6 +92,10 @@ static void sig_handler(int sig, siginfo_t *siginfo, void *context)
     ucontext_t *uc = (ucontext_t *)context;
     unsigned long pc = uc->uc_mcontext.pc;
     unsigned long sp = uc->uc_mcontext.gregs[29];
+    append_hosted_log(ROCKBOX_DIR "/crash.log",
+                      "signal=%d (%s) pc=%08lx sp=%08lx addr=%p",
+                      sig, strsignal(sig), pc, sp,
+                      siginfo ? siginfo->si_addr : NULL);
 
     lcd_putsf(0, line++, "%s at %08lx", strsignal(sig), pc);
 
@@ -130,6 +165,21 @@ void system_reboot(void)
     }
 }
 
+int system_set_audio_output_device(const char *device)
+{
+    if (!device || !*device)
+        return -1;
+
+    append_hosted_log(ROCKBOX_DIR "/bt_debug.log",
+                      "system_set_audio_output_device(%s)", device);
+    return pcm_alsa_switch_playback_device(device);
+}
+
+const char *system_get_audio_output_device(void)
+{
+    return pcm_alsa_get_playback_device();
+}
