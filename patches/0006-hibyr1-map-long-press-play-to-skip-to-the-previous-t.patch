From 7b9fd742b6b6df4dc2f3db367a92e3129cc16480 Mon Sep 17 00:00:00 2001
From: Michael McAllister <me@michaelmcallister.org>
Date: Tue, 21 Jul 2026 21:06:56 +0100
Subject: [PATCH] hibyr1: map long-press play to skip to the previous track

The HiBy R1 has no physical previous key, so the WPS had no way to skip
backwards. This changes it so a long press of play maps to the previous
track.

Prior to this change it was mapped to "stop", which is less common than
going to the previous track, and is already catered for by pause.
---
 apps/keymaps/keymap-hibyr3proii.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/apps/keymaps/keymap-hibyr3proii.c b/apps/keymaps/keymap-hibyr3proii.c
index 129e191341..14cd616673 100644
--- a/apps/keymaps/keymap-hibyr3proii.c
+++ b/apps/keymaps/keymap-hibyr3proii.c
@@ -47,7 +47,13 @@ static const struct button_mapping button_context_wps[] =
 {
     { ACTION_WPS_MENU,           BUTTON_POWER|BUTTON_REL,            BUTTON_POWER },
     { ACTION_WPS_PLAY,           BUTTON_PLAY|BUTTON_REL,             BUTTON_PLAY },
+#if defined(HIBY_R1)
+    /* The R1 has no physical "previous" key, so a long-press of PLAY skips to the previous track. */
+    { ACTION_NONE,               BUTTON_PLAY|BUTTON_REPEAT,          BUTTON_NONE },
+    { ACTION_WPS_SKIPPREV,       BUTTON_PLAY|BUTTON_REL,             BUTTON_PLAY|BUTTON_REPEAT },
+#else
     { ACTION_WPS_STOP,           BUTTON_PLAY|BUTTON_REPEAT,          BUTTON_NONE },
+#endif
     { ACTION_WPS_VOLUP,          BUTTON_VOL_UP|BUTTON_REL,           BUTTON_NONE },
     { ACTION_WPS_VOLDOWN,        BUTTON_VOL_DOWN|BUTTON_REL,         BUTTON_NONE },
     { ACTION_WPS_VOLUP,          BUTTON_VOL_UP|BUTTON_REPEAT,        BUTTON_NONE },
