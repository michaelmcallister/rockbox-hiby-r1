 firmware/SOURCES                  |   3 +
 firmware/target/hosted/pcm-alsa.c | 164 ++++++++++++++++++++++++++----
 2 files changed, 146 insertions(+), 21 deletions(-)

diff --git a/firmware/SOURCES b/firmware/SOURCES
index 20158f8489..262369dc0b 100644
--- a/firmware/SOURCES
+++ b/firmware/SOURCES
@@ -149,6 +149,9 @@ target/hosted/sonynwz/nwzlinux-codec.c
 #if ((defined(HIBY_LINUX) || defined(FIIO_M3K_LINUX) || defined(SAMSUNG_YPR0) || defined(SAMSUNG_YPR1) || defined(SONY_NWZ_LINUX)) && !defined(SIMULATOR))
 target/hosted/pcm-alsa.c
 target/hosted/alsa-controls.c
+#if (defined(HIBY_LINUX) && !defined(SIMULATOR))
+target/hosted/hiby/pcm-alsa-hiby.c
+#endif
 #endif
 #endif
 
diff --git a/firmware/target/hosted/pcm-alsa.c b/firmware/target/hosted/pcm-alsa.c
index 7e4833fdfe..ece1be6bb1 100644
--- a/firmware/target/hosted/pcm-alsa.c
+++ b/firmware/target/hosted/pcm-alsa.c
@@ -111,6 +111,87 @@ static snd_pcm_stream_t current_alsa_mode;  /* SND_PCM_STREAM_PLAYBACK / _CAPTUR
 
 static const char *current_alsa_device;
 
+void pcm_alsa_pump_locked(snd_pcm_t *handle);
+
+#ifndef _WIN32
+__attribute__((weak)) void pcm_alsa_adjust_buffering(snd_pcm_sframes_t *period_size,
+                                                      snd_pcm_sframes_t *buffer_size,
+                                                      const char *device)
+{
+    /* Default: no adjustment */
+    (void)period_size;
+    (void)buffer_size;
+    (void)device;
+}
+
+__attribute__((weak)) unsigned int pcm_alsa_calc_poll_interval(snd_pcm_sframes_t period_size,
+                                                                unsigned int sample_rate)
+{
+    /* Default: half the period duration in ms */
+    return (period_size * 500) / sample_rate;
+}
+
+__attribute__((weak)) snd_pcm_uframes_t pcm_alsa_start_threshold(snd_pcm_sframes_t buffer_size,
+                                                                   snd_pcm_sframes_t period_size,
+                                                                   const char *device)
+{
+    /* Default: start when buffer is half full */
+    (void)period_size;
+    (void)device;
+    return buffer_size / 2;
+}
+
+__attribute__((weak)) bool pcm_alsa_params_ready(snd_pcm_sframes_t period_size,
+                                                  snd_pcm_sframes_t buffer_size,
+                                                  sample_t *frames)
+{
+    /* Default: ready if all params are set */
+    return period_size > 0 && buffer_size > 0 && frames != NULL;
+}
+
+__attribute__((weak)) bool pcm_alsa_keep_device(snd_pcm_t *handle, const char *device,
+                                                 const char *current_device,
+                                                 snd_pcm_stream_t mode, snd_pcm_stream_t current_mode)
+{
+    /* Default: keep if same device and mode */
+    (void)handle;
+    return device == current_device
+#ifdef HAVE_RECORDING
+        && current_mode == mode
+#else
+        && true
+#endif
+        ;
+    (void)mode;
+    (void)current_mode;
+}
+
+__attribute__((weak)) void pcm_alsa_device_opened(snd_pcm_t *handle, const char *device,
+                                                   snd_pcm_stream_t mode, pthread_mutex_t *mtx)
+{
+    /* Default: no action */
+    (void)handle;
+    (void)device;
+    (void)mode;
+    (void)mtx;
+}
+
+__attribute__((weak)) void pcm_alsa_device_closing(snd_pcm_t *handle, const char *device)
+{
+    /* Default: no action */
+    (void)handle;
+    (void)device;
+}
+
+__attribute__((weak)) const char *pcm_alsa_open_fallback(const char *device, int err)
+{
+    /* Default: no fallback; let the caller treat the open failure as fatal. */
+    (void)device;
+    (void)err;
+    return NULL;
+}
+#endif
+
 void pcm_alsa_set_playback_device(const char *device)
 {
     playback_dev = device;
@@ -148,6 +229,8 @@ static int set_hwparams(snd_pcm_t *handle, unsigned long sampr)
         period_size = MIX_FRAME_SAMPLES;
     }
 
+    pcm_alsa_adjust_buffering(&period_size, &buffer_size, current_alsa_device);
+
     /* choose all parameters */
     err = snd_pcm_hw_params_any(handle, params);
     if (err < 0)
@@ -241,7 +324,8 @@ static int set_swparams(snd_pcm_t *handle)
         goto error;
     }
     /* start the transfer when the buffer is half full */
-    err = snd_pcm_sw_params_set_start_threshold(handle, swparams, buffer_size / 2);
+    err = snd_pcm_sw_params_set_start_threshold(handle, swparams,
+                                                  pcm_alsa_start_threshold(buffer_size, period_size, current_alsa_device));
     if (err < 0)
     {
         logf("Unable to set start threshold mode for playback: %s", snd_strerror(err));
@@ -381,20 +465,18 @@ static bool copy_frames(bool first)
     return true;
 }
 
-static void async_callback(snd_async_handler_t *ahandler)
+/* Pump audio frames to/from the ALSA device for one wakeup. The caller
+ * must already hold pcm_mtx. Used both by the async callback below and by
+ * the HiBy poll thread (target/hosted/hiby/pcm-alsa-hiby.c). */
+void pcm_alsa_pump_locked(snd_pcm_t *handle)
 {
     int err;
+    snd_pcm_state_t state;
 
-    if (!ahandler) return;
-
-    snd_pcm_t *handle = snd_async_handler_get_pcm(ahandler);
-
-    if (!handle) return;
-
-    if (pthread_mutex_trylock(&pcm_mtx) != 0)
+    if (!handle)
         return;
 
-    snd_pcm_state_t state = snd_pcm_state(handle);
+    state = snd_pcm_state(handle);
 
     if (state == SND_PCM_STATE_XRUN)
     {
@@ -403,19 +485,22 @@ static void async_callback(snd_async_handler_t *ahandler)
         err = snd_pcm_recover(handle, -EPIPE, 0);
         if (err < 0) {
             logf("XRUN Recovery error: %s", snd_strerror(err));
-            goto abort;
+            return;
         }
     }
     else if (state == SND_PCM_STATE_DRAINING)
     {
         logf("draining...");
-        goto abort;
+        return;
     }
     else if (state == SND_PCM_STATE_SETUP)
     {
-        goto abort;
+        return;
     }
 
+    if (state == SND_PCM_STATE_OPEN || !pcm_alsa_params_ready(period_size, buffer_size, frames))
+        return;
+
 #ifdef HAVE_RECORDING
     if (current_alsa_mode == SND_PCM_STREAM_PLAYBACK)
     {
@@ -433,7 +518,7 @@ static void async_callback(snd_async_handler_t *ahandler)
                     err = snd_pcm_recover(handle, -EPIPE, 0);
                     if (err < 0) {
                        logf("XRUN Recovery error: %s", snd_strerror(err));
-                       goto abort;
+                       return;
                     }
                     goto retry;
                 }
@@ -463,7 +548,7 @@ static void async_callback(snd_async_handler_t *ahandler)
                 err = snd_pcm_recover(handle, -EPIPE, 0);
                 if (err < 0) {
                    logf("XRUN Recovery error: %s", snd_strerror(err));
-                   goto abort;
+                   return;
                 }
 		continue;  /* buffer contents trashed, no sense in trying to copy */
             }
@@ -492,8 +577,24 @@ static void async_callback(snd_async_handler_t *ahandler)
             /* Depending on the error we might be SOL */
         }
     }
+}
+
+static void async_callback(snd_async_handler_t *ahandler)
+{
+    snd_pcm_t *handle;
+
+    if (!ahandler)
+        return;
+
+    handle = snd_async_handler_get_pcm(ahandler);
+    if (!handle)
+        return;
+
+    if (pthread_mutex_trylock(&pcm_mtx) != 0)
+        return;
+
+    pcm_alsa_pump_locked(handle);
 
-abort:
     pthread_mutex_unlock(&pcm_mtx);
 }
 
@@ -502,6 +603,7 @@ static void close_hwdev(void)
     logf("closedev (%p)", handle);
 
     if (handle) {
+        pcm_alsa_device_closing(handle, current_alsa_device);
         snd_pcm_drain(handle);
 #ifdef AUDIOHW_MUTE_ON_STOP
         audiohw_mute(true);
@@ -534,11 +636,13 @@ static void open_hwdev(const char *device, snd_pcm_stream_t mode)
 
     logf("opendev %s (%p)", device, handle);
 
-    if (handle && device == current_alsa_device
+    if (handle && pcm_alsa_keep_device(handle, device, current_alsa_device, mode,
 #ifdef HAVE_RECORDING
-        && current_alsa_mode == mode
+                                        current_alsa_mode
+#else
+                                        0
 #endif
-        )
+        ))
     {
         return;
     }
@@ -546,10 +650,28 @@ static void open_hwdev(const char *device, snd_pcm_stream_t mode)
     /* Close old handle */
     close_hwdev();
 
-    if ((err = snd_pcm_open(&handle, device, mode, 0)) < 0)
+    /* Open the device. A hot-pluggable sink (e.g. a Bluetooth A2DP route)
+     * can disappear between routing and open, so on failure ask the
+     * platform for a fallback device and retry. pcm_alsa_open_fallback()
+     * returns NULL once there is nothing left to fall back to, at which
+     * point the failure is genuinely fatal. */
+    while ((err = snd_pcm_open(&handle, device, mode, 0)) < 0)
     {
-        panicf("%s(): Cannot open device %s: %s", __func__, device, snd_strerror(err));
+        const char *fallback = pcm_alsa_open_fallback(device, err);
+
+        if (!fallback || fallback == device)
+            panicf("%s(): Cannot open device %s: %s",
+                   __func__, device, snd_strerror(err));
+
+        logf("open %s failed (%s); falling back to %s",
+             device, snd_strerror(err), fallback);
+        device = fallback;
+        /* Persist the fallback for the playback path so the next reopen
+         * does not retry the dead device. Capture uses its own target. */
+        if (mode == SND_PCM_STREAM_PLAYBACK)
+            playback_dev = fallback;
     }
+    pcm_alsa_device_opened(handle, device, mode, &pcm_mtx);
     last_sample_rate = 0;
 
     pthread_mutexattr_t attr;
