+/* Reopen the (new) playback device and resume pumping mid-stream after a
+ * route change. The audio engine does not re-issue its .play call when we
+ * switch devices under it, so closing the old handle would otherwise leave
+ * playback dead (handle NULL, pump stopped). Called from the HiBy route
+ * switch. Safe to call when not playing (it just (re)opens the device). */
+void pcm_alsa_restart_playback(void)
+{
+    const void *addr;
+    size_t size;
+
+    RBTRACE("restart_playback: dev='%s' handle=%p",
+            playback_dev ? playback_dev : "(null)", (void *)handle);
+
+    /* Open the new device (open_hwdev closes any stale handle first and
+     * starts the platform pump thread). */
+    open_hwdev(playback_dev, SND_PCM_STREAM_PLAYBACK);
+    if (!handle)
+    {
+        RBTRACE("restart_playback: open failed");
+        return;
+    }
+
+    /* Re-prime: pull the current playback buffer from the engine and run
+     * the normal start path (fill + snd_pcm_start) on the new device. If
+     * nothing is playing, the callback returns false and we just leave the
+     * device open for the next start. */
+    addr = NULL;
+    size = 0;
+    if (pcm_play_dma_complete_callback(PCM_DMAST_OK, &addr, &size) && addr && size)
+    {
+        RBTRACE("restart_playback: priming with %zu bytes", size);
+        sink_dma_start(addr, size);
+    }
+    else
+    {
+        RBTRACE("restart_playback: no active playback to resume");
+    }
+}
