[preset00]
fDecay=0.980
nWaveMode=0
zoom=1.008
cx=0.500
cy=0.500
warp=1.000
wave_r=0.700
wave_g=0.300
wave_b=0.900
per_frame_1=zoom = 1.006 + 0.015*bass;
per_frame_2=wave_r = 0.5 + 0.5*sin(time*0.9);
per_frame_3=wave_b = 0.5 + 0.5*cos(time*0.7);
per_pixel_1=rot = rot + 0.06*sin(ang*3 + time*0.8);
per_pixel_2=zoom = zoom + 0.03*cos(rad*9 - time*1.5);
